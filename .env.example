# Clave de API de Google Gemini
GEMINI_API_KEY=

# Prompt del sistema para el asistente
SYSTEM_PROMPT=

# Números autorizados para comandos administrativos (separados por coma, sin espacios)
# Ejemplo: ADMIN_NUMBERS=5491158647529,5493513782559
# Estos números pueden ejecutar comandos como PAUSAR BOT GLOBAL, REANUDAR BOT GLOBAL, etc.
ADMIN_NUMBERS=
