# =====================================
# DOLCE PARTY WHATSAPP BOT - CONFIGURACIÓN
# =====================================
# Copiar este archivo a .env y configurar según el entorno

# ─── ENTORNO ──────────────────────────
NODE_ENV=production
# Puerto para el dashboard centralizado (default: 3000)
DASHBOARD_CENTRAL_PORT=3000
# Puerto para el dashboard original (default: 3001)
DASHBOARD_ORIGINAL_PORT=3001

# ─── CORS PARA WEBSOCKET ─────────────
# En producción (VPS), cambiar por el dominio específico
# Ejemplo: https://dashboard.dolceparty.com
CORS_ORIGIN=*

# ─── INTERVALOS DE ACTUALIZACIÓN ─────
# Tiempo entre actualizaciones WebSocket en ms (default: 10000 = 10s)
WS_UPDATE_INTERVAL=10000

# ─── AGENTES (PUERTOS) ──────────────
# Puertos API para cada agente (deben coincidir con config/agents.json)
AGENT_SANTA_ANA_PORT=3011
AGENT_LOCAL2_PORT=3012

# ─── WHATSAPP ─────────────────────────
# Ruta base para sesiones de WhatsApp (default: ./.wwebjs_auth)
WHATSAPP_AUTH_PATH=./.wwebjs_auth
# Versión de WhatsApp Web (no cambiar si funciona)
WHATSAPP_VERSION=2.2412.54

# ─── API KEYS (LLM) ──────────────────
# Gemini API Key (https://ai.google.dev/)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# OpenRouter API Key (fallback - https://openrouter.ai/)
OPENROUTER_API_KEY=tu_api_key_de_openrouter_aqui
# Modelo de OpenRouter a usar (default: google/gemini-2.0-flash-exp:free)
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ─── RUTAS DE ARCHIVOS ───────────────
# Rutas relativas (no cambiar a menos que sea necesario)
DATA_PATH=./data
LOGS_PATH=./logs
CATALOGS_PATH=./catalogs

# ─── CONFIGURACIÓN DE REDIS (OPCIONAL) ─
# Para escalar a múltiples instancias en VPS
# REDIS_URL=redis://localhost:6379

# ─── LOGGING ──────────────────────────
# Nivel de logging: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ─── VPS SPECIFIC ────────────────────
# IP o dominio del servidor (para configurar CORS)
# SERVER_IP=123.456.789.0
# DOMAIN=dashboard.dolceparty.com

# ─── TIEMPOS DE REINTENTO ────────────
# Tiempo entre reintentos de LLM en ms (default: 3000)
LLM_RETRY_DELAY=3000
# Número máximo de reintentos (default: 3)
LLM_MAX_RETRIES=3

# ─── SEGURIDAD ───────────────────────
# Tiempo de auto-resume para usuarios pausados en ms (default: 1800000 = 30 min)
AUTO_RESUME_TIMEOUT_MS=1800000

# =====================================
# INSTRUCCIONES PARA VPS (HOSTINGER)
# =====================================
# 1. Instalar Node.js 18+ en el VPS
# 2. Clonar el repositorio
# 3. Copiar .env.example a .env: cp .env.example .env
# 4. Editar .env con tus API keys reales
# 5. Instalar dependencias: npm install
# 6. Instalar PM2 para mantener el bot corriendo: npm install -g pm2
# 7. Iniciar con PM2: pm2 start orchestrator.js --name "dolce-bot"
# 8. Ver logs: pm2 logs dolce-bot
# 9. Configurar Nginx como proxy inverso (opcional)
